# Copy this file to terraform.tfvars and fill in values before running.
# terraform.tfvars is gitignored — do not commit it.

aws_region    = "us-east-1"
instance_type = "t3.medium"
key_pair_name = "your-key-pair-name"
ecr_image_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/tinkar:latest"

# Lock these to ICA IP range(s) before deploying
allowed_cidrs = ["0.0.0.0/0"]
ssh_cidrs     = ["0.0.0.0/0"]
